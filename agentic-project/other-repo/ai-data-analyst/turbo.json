{
    "$schema": "https://turbo.build/schema.json",
    "tasks": {
        "dev": {
            "dependsOn": [
                "^dev"
            ],
            "cache": false
        },
        "build": {
            "dependsOn": [
                "^build"
            ],
            "outputs": [
                "dist/**",
                ".next/**"
            ]
        },
        "lint": {
            "outputs": []
        },
        "format": {
            "outputs": [],
            "cache": false
        }
    }
}